<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Tales Lanches</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      height: 100vh;
      background: url('https://images.unsplash.com/photo-1550547660-d9450f859349') no-repeat center;
      background-size: cover;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .overlay {
      background: rgba(0,0,0,0.80);
      width: 100%;
      height: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .container {
      width: 90%;
      max-width: 400px;
      text-align: center;
    }

    .logo {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      margin-bottom: 10px;
      border: 3px solid #FFD700;
      box-shadow: 0 0 20px rgba(255,215,0,0.6);
    }

    h1 {
      color: #FFD700;
      margin-bottom: 5px;
      font-size: 26px;
    }

    .desc {
      color: #ccc;
      margin-bottom: 15px;
    }

    .promo {
      background: linear-gradient(90deg, #FFD700, #ffae00);
      color: #000;
      padding: 12px;
      border-radius: 12px;
      font-weight: bold;
      margin-bottom: 15px;
      animation: pulse 1.5s infinite;
      box-shadow: 0 0 15px rgba(255, 215, 0, 0.6);
    }

    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.05); }
      100% { transform: scale(1); }
    }

    .btn {
      display: flex;
      align-items: center;
      gap: 12px;
      background: #fff;
      color: #000;
      padding: 14px;
      margin: 10px 0;
      border-radius: 12px;
      text-decoration: none;
      font-weight: bold;
      transition: 0.3s;
    }

    .btn img {
      width: 28px;
    }

    .btn:hover {
      transform: scale(1.05);
    }

    .whatsapp {
      background: #25D366;
      color: #fff;
      animation: zap 1s infinite;
    }

    @keyframes zap {
      0% { box-shadow: 0 0 0px #25D366; }
      50% { box-shadow: 0 0 20px #25D366; }
      100% { box-shadow: 0 0 0px #25D366; }
    }

    .footer {
      margin-top: 15px;
      font-size: 12px;
      color: #aaa;
    }
  </style>
</head>

<body>

<div class="overlay">
  <div class="container">

    <!-- LOGO -->
    <img src="https://i.imgur.com/8Km9tLL.png" class="logo">

    <h1>Tales Lanches</h1>
    <p class="desc">O lanche mais brabo da região 🔥</p>

    <!-- PROMO -->
    <div class="promo">
      💥 Promoções quase todos os dias! Fique de olho 👀
    </div>

    <!-- BOTÕES -->

    <a class="btn" href="https://sl1nk.com/taleslanchescardapio" target="_blank">
      <img src="https://cdn-icons-png.flaticon.com/512/1046/1046784.png">
      Ver Cardápio
    </a>

    <a class="btn whatsapp" href="https://wa.me/5514999060536?text=Olá,%20vim%20pelo%20Instagram%20e%20quero%20fazer%20um%20pedido!" target="_blank">
      <img src="https://cdn-icons-png.flaticon.com/512/733/733585.png">
      Pedir no WhatsApp
    </a>

    <a class="btn" href="https://aiqfome.com/SP/brotas/tales-lanches" target="_blank">
      <img src="https://cdn-icons-png.flaticon.com/512/3075/3075977.png">
      Pedir pelo App (AiqFome)
    </a>

    <a class="btn" href="https://www.instagram.com/lanchestales" target="_blank">
      <img src="https://cdn-icons-png.flaticon.com/512/2111/2111463.png">
      Nosso Instagram
    </a>

    <div class="footer">
      © Tales Lanches
    </div>

  </div>
</div>

</body>
</html> 
